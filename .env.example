# Password for the /admin content manager. Defaults to "admin" if unset.
ADMIN_PASSWORD=admin

# OpenAI API key — powers the floating "Ask me anything" assistant (/api/chat).
# Get one at https://platform.openai.com/api-keys
# Copy this file to .env.local and paste your key there, then restart `npm run dev`.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email notifications — the assistant emails you when a visitor leaves a lead,
# order, request, or opinion. Powered by Resend (https://resend.com), which has
# a free tier. Leave RESEND_API_KEY blank to disable email (capture still works;
# items are stored and viewable at /admin).
#   1. Sign up at resend.com and create an API key at resend.com/api-keys
#   2. Paste it below.
# The default sender (onboarding@resend.dev) only delivers to the email that owns
# your Resend account — perfect for notifying yourself. IMPORTANT: it is
# case-sensitive, so NOTIFY_EMAIL_TO must match your Resend account email exactly
# (all lowercase). To send to any recipient, verify a domain at resend.com/domains
# and set NOTIFY_EMAIL_FROM to an address on it.
# NOTE: put real values in .env.local, NOT here — this file is committed to git.
RESEND_API_KEY=
NOTIFY_EMAIL_TO=bnampellah1@gmail.com
NOTIFY_EMAIL_FROM=Nampellah Portfolio <onboarding@resend.dev>
