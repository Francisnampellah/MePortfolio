# Password for the /admin content manager. Defaults to "admin" if unset.
ADMIN_PASSWORD=admin

# Anthropic API key — powers the floating AI assistant (/api/chat).
# Get one at https://console.anthropic.com . Without it, the assistant
# returns a friendly fallback message instead of live answers.
ANTHROPIC_API_KEY=

# Optional: override the model (defaults to claude-3-5-haiku-latest).
ANTHROPIC_MODEL=claude-3-5-haiku-latest
