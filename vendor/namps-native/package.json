{
  "name": "namps-native",
  "version": "1.0.0",
  "description": "namps-native — a calm, premium, token-driven React Native UI library. Typography-first, fully typed, agent-friendly.",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "keywords": [
    "react-native",
    "expo",
    "ui",
    "design-system",
    "components",
    "typescript",
    "reanimated",
    "dark-mode"
  ]
}
