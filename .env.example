# Password for the /admin content manager. Defaults to "admin" if unset.
ADMIN_PASSWORD=admin

# OpenAI API key — powers the floating "Ask me anything" assistant (/api/chat).
# Get one at https://platform.openai.com/api-keys . Copy this file to .env.local
# and set your key there. Without it, the assistant returns a friendly fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
